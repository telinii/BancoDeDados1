-- QUEM CRIOU A TABELA PRODUTO PODE APAGA-LA
DROP TABLE produto


--  CRIAR A TABELA PRODUTO COM PK MAS AINDA SEM FK
CREATE TABLE produto(
	idPro int PRIMARY KEY IDENTITY(1,1),
	nome varchar(100),
	preco money,
	cor varchar(40),
	idMarca int FOREIGN KEY REFERENCES marca(idMarca)
)

