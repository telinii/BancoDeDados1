CREATE DATABASE Restaurante

USE Restaurante

--tabela de atendimentos
CREATE TABLE ATENDIMENTO(
CodAtendimento int PRIMARY KEY IDENTITY (1,1),
Situacao varchar(80),
DtHrChegada date,
NroPessoas int,


idGarcom int FOREIGN KEY REFERENCES GARCOM(CodGarcom),


idMesa int FOREIGN KEY REFERENCES MESA(NroMesa)
)

ALTER TABLE ATENDIMENTO
ADD CodGarsom int FOREIGN KEY REFERENCES GARCOM(CodGarsom)
ALTER TABLE ATENDIMENTO
ADD NroMesa int FOREIGN KEY REFERENCES MESA(NroMesa)



--tabela de mesa
CREATE TABLE MESA(
NroMesa int PRIMARY KEY IDENTITY(1,1),
Setor varchar(80),
Capacidade int,
Situacao varchar(80)
)

--tabela de produto
CREATE TABLE PRODUTO(
CodPro int PRIMARY KEY IDENTITY(1,1),
Descricao varchar(80),
Preco money
)

--tabela de garcom
CREATE TABLE GARCOM(
CodGarsom int PRIMARY KEY IDENTITY(1,1),
Nome varchar (90),
CalcularComissao money
)

CREATE TABLE CONSUMO(
CodPro int FOREIGN KEY REFERENCES PRODUTO(CodPro),
CodAtendimento int FOREIGN KEY REFERENCES ATENDIMENTO(CodAtendimento),
Qtde int,
Vlunit money
)

ALTER TABLE CONSUMO
ADD idConsumo int


