CREATE TABLE pacientes(
Codpac INT PRIMARY KEY IDENTITY(1,1),
nome varchar(80),
fone varchar(30)
)

CREATE TABLE consultas(
codCon INT PRIMARY KEY IDENTITY(1,1), --PK COM AUTONUMERAÇÃO
dataCon DATE,
codMed int FOREIGN KEY REFERENCES medicos(idMedico) NOT NULL, --CAMPO OBRIGATORIO
CodPac int FOREIGN KEY REFERENCES pacientes(Codpac) NOT NULL, --CAMPO OBRIGATORIO
)

SELECT M.nome as nomeMedico, P.nome as nomePaciente
FROM
	medicos AS M INNER JOIN consultas AS C
				ON M.idMedico = C.codMed
				INNER JOIN pacientes AS P
				ON P.codPac = C.codPac
				INNER JOIN especialidades AS E
				ON E.idEspecialidade = M.idEspecialidade
WHERE
	C.dataCon >= '2026/05/01' AND C.dataCon <= '2026/05/31'
	AND e.nome = 'PEDIATRA'
    
